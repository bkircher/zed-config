[
  {
    "context": "Editor && showing_completions && vim_mode == insert",
    "bindings": {
      "enter": "editor::Newline",
      "ctrl-enter": "editor::ConfirmCompletion",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "ctrl-p": "editor::ShowCompletions",
    },
  },
  {
    "context": "EmptyPane || SharedScreen || vim_operator == none && !VimWaiting && vim_mode != insert",
    "bindings": {
      "ctrl-r": "projects::OpenRecent",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-[": "pane::GoBack",
      "ctrl-]": "pane::GoForward",
    },
  },
]
